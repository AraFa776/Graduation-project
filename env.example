# AI Chatbot (server-side only — never expose keys to the browser)

# Provider: gemini (recommended) | openai | cursor | mock
# Default when unset: gemini (with automatic fallback chain)
AI_PROVIDER=gemini

# --- Gemini (recommended production provider) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Cursor (NOT for in-app medical chat) ---
# Cursor Pro / @cursor/sdk = Cloud Agents for code automation only.
# If AI_PROVIDER=cursor and Cursor chat API is unavailable, system falls back to Gemini → OpenAI → mock.
CURSOR_API_KEY=
CURSOR_MODEL=

# --- Mock (local testing, always works) ---
# AI_PROVIDER=mock

# Legacy aliases (OpenAI-compatible)
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

# Upload limits
CHATBOT_MAX_FILE_BYTES=10485760
CHATBOT_UPLOAD_DIR=storage/chatbot
